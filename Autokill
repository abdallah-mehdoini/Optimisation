	BEGIN
		---------------------------------------------------
		-- CURSEUR POUR KILLER LES PROCESS "WEB" BLOQUES --
		---------------------------------------------------
	

		DECLARE CURS_MON_PROCESS CURSOR FORWARD_ONLY FOR
		
		
			SELECT SESSION_ID, DATEDIFF(SECOND, START_TIME, GETDATE()), LOGIN_NAME, CAST(SQL_TEXT AS VARCHAR(MAX)), SUBSTRING(CAST(SQL_COMMAND AS VARCHAR(MAX)),0, 100)
			FROM #_TMP_WHOISACTIVE
			WHERE LOGIN_NAME = 'IUSR_BITEAM'
			AND (
				(DATEDIFF(SECOND, START_TIME, GETDATE()) >=  9000 )
			--	OR	(CPU > '5000000' OR READS > '1000000') )
				)
				
		

		OPEN CURS_MON_PROCESS
		FETCH NEXT FROM CURS_MON_PROCESS INTO @SESSION_ID, @TOTALTIME, @LOGINNAME, @SQL_TEXT, @SQL_COMMAND
		WHILE (@@FETCH_STATUS <> -1)
		BEGIN
			  IF (@@FETCH_STATUS <> -2)
			  BEGIN
				SET @SUBJECT = '[02PZ][!][Requête > 8heure] Process ' + REPLACE(@LOGINNAME, 'IUSR_', '') + ' en timeout'
				SET @BODY = 'La requête ' + REPLACE(@LOGINNAME, 'IUSR_', '') + ' numéro ' + CAST(@SESSION_ID AS VARCHAR(4)) + ' tourne depuis ' + CONVERT(VARCHAR,@TOTALTIME) + ' secondes. <br /><br />'
