				--	   , @recipients= @RECIPIENTS
				--	   , @copy_recipients = ''
				--	   , @subject = @SUBJECT
				--	   , @body = @BODY
				--	   , @body_format = 'HTML'
				--	   , @importance = 'HIGH';
				
				EXEC ('KILL ' + @SESSION_ID)
			   	
			  END
			  FETCH NEXT FROM CURS_MON_PROCESS INTO @SESSION_ID, @TOTALTIME, @LOGINNAME, @SQL_TEXT, @SQL_COMMAND
		END
		DEALLOCATE CURS_MON_PROCESS

		INSERT INTO [DACODAQ].[dbo].[ADM_AUTO_KILL_LOG]
			(
			[COLLECTION_TIME],
			[START_TIME],
			[DD HH:MM:SS.MSS],
			[SESSION_ID],
			[SQL_TEXT],
			[SQL_COMMAND],
			[LOGIN_NAME],
			[WAIT_INFO],
			[CPU],
			[READS],
			[BLOCKING_SESSION_ID],
			[KILL_MODE],
			[DATE_FIN]
			)
		SELECT [COLLECTION_TIME],
				[START_TIME],
				[DD HH:MM:SS.MSS],
				SESSION_ID,
				ISNULL(REPLACE(REPLACE(CAST(SQL_TEXT AS VARCHAR(MAX)), '--?>',''), '<?query --', ''), 'SQL_Text inconnue'),
				CAST(SQL_COMMAND AS NVARCHAR(MAX)),
				LOGIN_NAME,
				[WAIT_INFO],
				RTRIM([CPU]),
				RTRIM([READS]),
				NULL                     AS [BLOCKING_SESSION_ID],
				CASE 
					WHEN DATEDIFF(SECOND, START_TIME, GETDATE()) >= 9000 THEN 'CRITICAL'
					ELSE 'WARNING' END  AS [KILL_MODE],
				CAST(GETDATE() AS DATE)  AS [DATE_FIN]
		FROM   #_TMP_WHOISACTIVE
		WHERE (
				(DATEDIFF(SECOND, START_TIME, GETDATE()) >= 9000 ) 
				--OR	(CPU > '1000000' OR READS > '1000000') )
				)
				AND LOGIN_NAME IN ('IUSR_BITEAM')

